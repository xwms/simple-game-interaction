{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@shared/types": ["./src/shared/types"]
    }
  },
  "include": ["src/**/*", "scripts/**/*"]
}
