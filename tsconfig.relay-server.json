{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist/relay-server",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/relay-server/**/*.ts"
  ],
  "exclude": [
    "src/relay-server/_archive"
  ]
}
