{
  "name": "simple-game-interaction",
  "version": "0.1.0",
  "description": "局域网游戏联机工具 — 帮助非技术用户将单机局域网联机游戏通过互联网进行联机",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:vite": "vite",
    "relay": "tsx src/relay-server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts,.vue",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@iconify/vue": "^4.3.0",
    "@unocss/reset": "^66.7.0",
    "naive-ui": "^2.44.0",
    "pinia": "^2.2.0",
    "unocss": "^66.7.0",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@unocss/vite": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.0",
    "sass": "^1.100.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
