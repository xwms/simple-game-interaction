{
  "name": "simple-game-interaction",
  "version": "0.1.4",
  "description": "局域网游戏联机工具 — 帮助非技术用户将单机局域网联机游戏通过互联网进行联机",
  "author": {
    "name": "xwms",
    "email": "xwms@github.com"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:vite": "vite",
    "relay": "tsx src/relay-server/main.ts",
    "relay:build": "tsc --project tsconfig.relay-server.json",
    "relay:prod": "node dist/relay-server/main.js",
    "build:main": "node scripts/build-main.js",
    "build:renderer": "vite build",
    "build": "node scripts/build-main.js && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts,.vue",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/build-main.js && playwright test --config=tests/e2e/playwright.config.ts",
    "pack": "node scripts/build-main.js && vite build && electron-builder --dir",
    "dist": "node scripts/build-main.js && vite build && electron-builder",
    "dist:win": "node scripts/build-main.js && vite build && electron-builder --win",
    "dist:mac": "node scripts/build-main.js && vite build && electron-builder --mac",
    "dist:linux": "node scripts/build-main.js && vite build && electron-builder --linux"
  },
  "dependencies": {
    "@unocss/reset": "^66.7.0",
    "denque": "^2.1.0",
    "dompurify": "^3.4.8",
    "marked": "^18.0.5",
    "naive-ui": "^2.44.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@unocss/preset-typography": "^66.7.0",
    "@unocss/vite": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.0",
    "sass": "^1.100.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
